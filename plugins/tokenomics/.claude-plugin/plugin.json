{
  "name": "tokenomics",
  "version": "1.3.0",
  "description": "Token usage, cache hit rates, and Max plan consumption analyzer for Claude Code sessions. Ships an opt-in SessionStart hook that schedules a /loop to keep the prompt cache warm.",
  "author": {
    "name": "Victor De Simone",
    "email": "victorsmoliveira@gmail.com",
    "url": "https://github.com/vdsmon"
  },
  "homepage": "https://github.com/vdsmon/claude-skills",
  "repository": "https://github.com/vdsmon/claude-skills",
  "license": "MIT",
  "skills": "./skills",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/tokenomics-keepalive.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
